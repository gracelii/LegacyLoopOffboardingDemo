# --- U-M GPT Toolkit (OpenAI-compatible gateway) ---
# Create/retrieve a key at https://toolkit.umgpt.umich.edu/
UMGPT_API_KEY=...
UMGPT_API_BASE=https://api.toolkit.umgpt.umich.edu/v1

# --- Postgres / pgvector ---
PG_HOST=localhost
PG_PORT=5432
PG_DB=offboarding
PG_USER=postgres
PG_PASSWORD=

# --- Google Drive (service account auth) ---
# Path to the service account JSON key file.
# Download from Google Cloud Console → IAM & Admin → Service Accounts → Keys.
# Share the input folder with the service account email (Viewer).
# Share the output folder with the service account email (Editor).
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# ID of the Drive folder to ingest (input -- employee docs live here).
# Right-click the folder in Drive → "Get link" → copy the ID from the URL after /folders/
DRIVE_FOLDER_ID=

# ID of the Drive folder where completed interview summaries will be written (output).
DRIVE_OUTPUT_FOLDER_ID=
