# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Postgres / pgvector ---
PG_HOST=localhost
PG_PORT=5432
PG_DB=offboarding
PG_USER=postgres
PG_PASSWORD=changeme

# --- Google Drive ---
# Path to a Google Cloud OAuth client secret JSON (Desktop app type)
# Create one at https://console.cloud.google.com/apis/credentials
# Enable the "Google Drive API" for the project first.
GOOGLE_CLIENT_SECRET_FILE=client_secret.json
# Token will be cached here after first interactive auth
GOOGLE_TOKEN_FILE=token.json

# ID of the Drive folder to ingest (right-click folder > "Get link" > grab the ID from the URL)
DRIVE_FOLDER_ID=
